# Changelog Generator Configuration
# Copy this file to .env and fill in your actual values

# Provider: openai, anthropic, or other pydantic-ai supported providers
CHANGELOG_PROVIDER=openai

# Model name (without provider prefix)
CHANGELOG_MODEL=gpt-4o-mini

# API Key for the provider
CHANGELOG_API_KEY=your-api-key-here

# Optional: Release date (YYYY-MM-DD), defaults to today
CHANGELOG_DATE=

# Optional: Git revision range (e.g., v0.1.1..HEAD), defaults to commits since last tag
CHANGELOG_REV_RANGE=dev..main

# Optional: Documentation scope (comma-separated, e.g., curriculum,architecture)
CHANGELOG_DOCS_SCOPE=
